# Copy to .env (cp .env.example .env). Optional — only needed to relocate the
# model cache (e.g. onto a shared NAS) or to run offline.

# ---- Where model weights live and download to ----
# HuggingFace downloads weights straight into this cache and reads them back
# from it; this is both the download destination and the store.
# Leave unset for the local cache (~/.cache/huggingface). Point it at an NFS
# mount to share weights across servers (first run downloads onto the NAS).
# HF_CACHE_DIR=/mnt/ai-models/huggingface

# Set to 1 once weights are pre-staged on a read-only/NFS cache.
# HF_HUB_OFFLINE=1
